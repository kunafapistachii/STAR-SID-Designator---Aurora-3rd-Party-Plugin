# Aurora STAR/SID Designator - Configuration
# Copy to .env and fill in your values

# Aurora connection
AURORA_HOST=localhost
AURORA_PORT=1130

# Path to your Aurora SectorFiles/Include/<FIR>/Airports/ folder
# Example: C:/IVAO/Aurora/SectorFiles/Include/WIIF/Airports
SECTOR_FILES_PATH=F:\Aurora\SectorFiles\Include\WIIF\Airports

# Polling interval in seconds (how often to refresh traffic from Aurora)
POLL_INTERVAL=5

# Web server port
WEB_PORT=8080

# Set to true to run with mock data (no Aurora connection needed)
DEMO_MODE=false
